# LLM API Keys (at least one required)
OPENROUTER_API_KEY=sk-or-...   # Free tier available at openrouter.ai
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GEMINI_API_KEY=...
OPENAI_API_KEY=sk-...

# Google Sheets (service account)
GOOGLE_SHEETS_CREDENTIALS_FILE=config/google_credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Email (Gmail app password)
EMAIL_SENDER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password
EMAIL_RECIPIENT=iknoest@gmail.com

# Travel time
HOME_STATION=Hoofddorp
ARRIVAL_TIME=09:00

# n8n webhook (for manual trigger)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/jobsearch-trigger
